# ─── Chat App Environment Configuration ───────────────────────────────
# Copy this file to `.env` and update the values for your environment.
# This file is loaded at runtime by flutter_dotenv — no build_runner needed.
#
# For ngrok (same URL works on both Chrome and mobile emulator):
#   API_URL=https://your-subdomain.ngrok-free.app
#   SOCKET_URL=https://your-subdomain.ngrok-free.app

# API / Server
API_URL=http://localhost:3000
SOCKET_URL=http://localhost:3000

# AWS S3
S3_BUCKET_URL=https://s3.amazonaws.com/your-bucket-name

# Firebase (optional — only needed for push notifications)
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=

# Database Encryption
DB_ENCRYPTION_KEY=change-me-to-a-32-char-key-here!
